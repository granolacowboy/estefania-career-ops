---
interface Props {
  name: string;
  headline: string;
  location: string;
}

const { name, headline, location } = Astro.props;
---

<header class="bg-brand-600 text-white">
  <div class="mx-auto max-w-5xl px-4 py-5 sm:px-6 sm:py-8">
    <div class="flex items-start justify-between gap-3">
      <div>
        <h1 class="text-2xl font-bold sm:text-3xl">{name}</h1>
        {headline && <p class="mt-1 text-brand-200 text-sm sm:text-base">{headline}</p>}
        <p class="mt-1 text-brand-300 text-sm">{location}</p>
      </div>
      <button
        id="theme-toggle"
        class="shrink-0 rounded-full p-2 text-brand-200 transition-colors hover:bg-brand-500 hover:text-white cursor-pointer"
        title="Cambiar tema"
        aria-label="Cambiar tema claro/oscuro"
      >
        <svg class="h-5 w-5 block dark:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" />
        </svg>
        <svg class="h-5 w-5 hidden dark:block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" />
        </svg>
      </button>
    </div>
  </div>
</header>

<script>
  document.getElementById('theme-toggle')?.addEventListener('click', () => {
    document.documentElement.classList.toggle('dark');
    localStorage.setItem(
      'theme',
      document.documentElement.classList.contains('dark') ? 'dark' : 'light'
    );
  });
</script>
