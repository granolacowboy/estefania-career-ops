---
/**
 * ApplyPanel — inline draft editor that expands below a JobCard.
 * Rendered as a hidden container; client-side JS populates it
 * when the user clicks "Preparar Aplicación" or "Ver Borrador".
 *
 * All interaction is client-side (fetch to /api/* endpoints).
 */

interface Props {
  jobNum: string;
  hasDraft: boolean;
}

const { jobNum, hasDraft } = Astro.props;
const panelId = `apply-panel-${jobNum}`;
---

<div
  id={panelId}
  data-apply-panel
  data-job-num={jobNum}
  data-has-draft={hasDraft ? 'true' : 'false'}
  class="hidden mt-2 rounded-lg border border-brand-100 bg-brand-50/50 p-4 dark:border-brand-700 dark:bg-brand-900/50"
>
  <!-- Loading state -->
  <div data-panel-state="loading" class="flex items-center gap-3 py-8 justify-center">
    <svg class="h-5 w-5 animate-spin text-brand-500 dark:text-brand-400" viewBox="0 0 24 24" fill="none">
      <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
      <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
    </svg>
    <span class="text-sm text-brand-600 dark:text-brand-300">Preparando tus materiales...</span>
  </div>

  <!-- Error state -->
  <div data-panel-state="error" class="hidden py-6 text-center">
    <p class="text-sm text-red-600 dark:text-red-400" data-error-msg>Algo salió mal. Inténtalo de nuevo.</p>
    <button
      data-action="retry-generate"
      class="mt-2 rounded-md bg-brand-500 px-3 py-1.5 text-xs font-medium text-white hover:bg-brand-600 cursor-pointer"
    >
      Reintentar
    </button>
  </div>

  <!-- Ready state: tabs + content -->
  <div data-panel-state="ready" class="hidden">
    <!-- Tab bar -->
    <div class="flex gap-1 border-b border-brand-200 mb-4 dark:border-brand-700">
      <button data-tab="carta" class="px-3 py-2 text-sm font-medium text-brand-700 border-b-2 border-brand-500 cursor-pointer dark:text-brand-200">
        Carta
      </button>
      <button data-tab="preguntas" class="px-3 py-2 text-sm font-medium text-gray-500 border-b-2 border-transparent hover:text-brand-600 cursor-pointer dark:text-brand-400 dark:hover:text-brand-200">
        Preguntas
      </button>
      <button data-tab="linkedin" class="px-3 py-2 text-sm font-medium text-gray-500 border-b-2 border-transparent hover:text-brand-600 cursor-pointer dark:text-brand-400 dark:hover:text-brand-200">
        LinkedIn
      </button>
    </div>

    <!-- Tab: Cover Letter -->
    <div data-tab-content="carta">
      <div class="flex items-center justify-between mb-2">
        <span class="text-xs font-medium text-gray-500 dark:text-brand-400">Carta de presentación</span>
        <div class="flex items-center gap-1">
          <button data-action="feedback" data-section="cover_letter" data-signal="up" class="rounded p-1.5 text-gray-400 hover:bg-emerald-50 hover:text-emerald-600 cursor-pointer dark:text-brand-500 dark:hover:bg-emerald-900/30 dark:hover:text-emerald-400" title="Me gusta">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M14 9V5a3 3 0 00-3-3l-4 9v11h11.28a2 2 0 002-1.7l1.38-9a2 2 0 00-2-2.3H14z"/></svg>
          </button>
          <button data-action="feedback" data-section="cover_letter" data-signal="down" class="rounded p-1.5 text-gray-400 hover:bg-red-50 hover:text-red-600 cursor-pointer dark:text-brand-500 dark:hover:bg-red-900/30 dark:hover:text-red-400" title="No me gusta">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M10 15v4a3 3 0 003 3l4-9V2H5.72a2 2 0 00-2 1.7l-1.38 9a2 2 0 002 2.3H10z"/></svg>
          </button>
          <button data-action="copy" data-target="cover-letter-text" class="rounded px-2 py-1 text-xs text-brand-600 hover:bg-brand-100 cursor-pointer dark:text-brand-400 dark:hover:bg-brand-800">
            Copiar
          </button>
        </div>
      </div>
      <textarea
        data-field="cover-letter-text"
        rows="10"
        class="w-full rounded-md border border-gray-200 bg-white p-3 text-sm leading-relaxed text-gray-700 focus:border-brand-400 focus:outline-none focus:ring-1 focus:ring-brand-400 resize-y dark:border-brand-700 dark:bg-brand-800 dark:text-brand-200"
        placeholder="Tu cover letter aparecerá aquí..."
      ></textarea>
    </div>

    <!-- Tab: Q&A -->
    <div data-tab-content="preguntas" class="hidden">
      <div data-questions-container class="space-y-4">
        <!-- Populated by JS -->
      </div>
    </div>

    <!-- Tab: LinkedIn -->
    <div data-tab-content="linkedin" class="hidden">
      <div class="space-y-4">
        <!-- Hiring Manager -->
        <div>
          <div class="flex items-center justify-between mb-1">
            <span class="text-xs font-medium text-gray-500 dark:text-brand-400">Hiring Manager</span>
            <div class="flex items-center gap-1">
              <button data-action="feedback" data-section="linkedin_hm" data-signal="up" class="rounded p-1.5 text-gray-400 hover:bg-emerald-50 hover:text-emerald-600 cursor-pointer dark:text-brand-500 dark:hover:bg-emerald-900/30 dark:hover:text-emerald-400" title="Me gusta">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M14 9V5a3 3 0 00-3-3l-4 9v11h11.28a2 2 0 002-1.7l1.38-9a2 2 0 00-2-2.3H14z"/></svg>
              </button>
              <button data-action="feedback" data-section="linkedin_hm" data-signal="down" class="rounded p-1.5 text-gray-400 hover:bg-red-50 hover:text-red-600 cursor-pointer dark:text-brand-500 dark:hover:bg-red-900/30 dark:hover:text-red-400" title="No me gusta">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M10 15v4a3 3 0 003 3l4-9V2H5.72a2 2 0 00-2 1.7l-1.38 9a2 2 0 002 2.3H10z"/></svg>
              </button>
              <button data-action="copy" data-target="linkedin-hm-text" class="rounded px-2 py-1 text-xs text-brand-600 hover:bg-brand-100 cursor-pointer dark:text-brand-400 dark:hover:bg-brand-800">
                Copiar
              </button>
            </div>
          </div>
          <textarea
            data-field="linkedin-hm-text"
            rows="3"
            maxlength="300"
            class="w-full rounded-md border border-gray-200 bg-white p-3 text-sm text-gray-700 focus:border-brand-400 focus:outline-none focus:ring-1 focus:ring-brand-400 resize-y dark:border-brand-700 dark:bg-brand-800 dark:text-brand-200"
          ></textarea>
          <p class="mt-1 text-right text-xs text-gray-400 dark:text-brand-500"><span data-char-count="linkedin-hm-text">0</span>/300</p>
        </div>
        <!-- Recruiter -->
        <div>
          <div class="flex items-center justify-between mb-1">
            <span class="text-xs font-medium text-gray-500 dark:text-brand-400">Recruiter</span>
            <div class="flex items-center gap-1">
              <button data-action="feedback" data-section="linkedin_rec" data-signal="up" class="rounded p-1.5 text-gray-400 hover:bg-emerald-50 hover:text-emerald-600 cursor-pointer dark:text-brand-500 dark:hover:bg-emerald-900/30 dark:hover:text-emerald-400" title="Me gusta">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M14 9V5a3 3 0 00-3-3l-4 9v11h11.28a2 2 0 002-1.7l1.38-9a2 2 0 00-2-2.3H14z"/></svg>
              </button>
              <button data-action="feedback" data-section="linkedin_rec" data-signal="down" class="rounded p-1.5 text-gray-400 hover:bg-red-50 hover:text-red-600 cursor-pointer dark:text-brand-500 dark:hover:bg-red-900/30 dark:hover:text-red-400" title="No me gusta">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M10 15v4a3 3 0 003 3l4-9V2H5.72a2 2 0 00-2 1.7l-1.38 9a2 2 0 002 2.3H10z"/></svg>
              </button>
              <button data-action="copy" data-target="linkedin-rec-text" class="rounded px-2 py-1 text-xs text-brand-600 hover:bg-brand-100 cursor-pointer dark:text-brand-400 dark:hover:bg-brand-800">
                Copiar
              </button>
            </div>
          </div>
          <textarea
            data-field="linkedin-rec-text"
            rows="3"
            maxlength="300"
            class="w-full rounded-md border border-gray-200 bg-white p-3 text-sm text-gray-700 focus:border-brand-400 focus:outline-none focus:ring-1 focus:ring-brand-400 resize-y dark:border-brand-700 dark:bg-brand-800 dark:text-brand-200"
          ></textarea>
          <p class="mt-1 text-right text-xs text-gray-400 dark:text-brand-500"><span data-char-count="linkedin-rec-text">0</span>/300</p>
        </div>
      </div>
    </div>

    <!-- Action bar -->
    <div class="mt-4 flex items-center justify-between border-t border-brand-100 pt-3 dark:border-brand-700">
      <button
        data-action="save-drafts"
        class="rounded-md bg-brand-500 px-4 py-2.5 text-sm font-medium text-white hover:bg-brand-600 cursor-pointer"
      >
        Guardar cambios
      </button>
      <button
        data-action="mark-applied"
        class="hidden rounded-md border border-emerald-300 bg-emerald-50 px-4 py-2.5 text-sm font-medium text-emerald-700 hover:bg-emerald-100 cursor-pointer dark:border-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-300 dark:hover:bg-emerald-800/40"
      >
        Marcar como Aplicado
      </button>
    </div>

    <!-- Toast -->
    <div data-toast class="hidden mt-3 rounded-md bg-emerald-50 px-3 py-2 text-center text-xs font-medium text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-300"></div>
  </div>
</div>
