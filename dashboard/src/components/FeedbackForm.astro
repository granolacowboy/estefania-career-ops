---
---

<div class="rounded-lg border border-brand-100 bg-white p-4 dark:border-brand-700 dark:bg-dark-card">
  <h3 class="text-sm font-semibold text-brand-800 dark:text-brand-100">Comentarios y sugerencias</h3>
  <p class="mt-1 text-xs text-gray-500 dark:text-brand-400">¿Algo que mejorar? ¿Una función que necesitas?</p>

  <form id="feedback-form" class="mt-3">
    <div class="flex gap-2">
      <select id="feedback-type" class="rounded border border-gray-200 px-2 py-1.5 text-xs text-gray-700 dark:border-brand-700 dark:bg-brand-800 dark:text-brand-200">
        <option value="feedback">Comentario</option>
        <option value="feature">Sugerencia</option>
      </select>
      <input
        id="feedback-msg"
        type="text"
        placeholder="Escribe tu mensaje..."
        class="flex-1 rounded border border-gray-200 px-3 py-1.5 text-sm text-gray-700 placeholder:text-gray-300 focus:border-brand-300 focus:outline-none dark:border-brand-700 dark:bg-brand-800 dark:text-brand-100 dark:placeholder:text-brand-600"
        maxlength="500"
        required
      />
      <button
        type="submit"
        id="feedback-btn"
        class="rounded-lg bg-brand-500 px-3 py-1.5 text-xs font-semibold text-white transition-colors hover:bg-brand-600 active:scale-95 cursor-pointer"
      >
        Enviar
      </button>
    </div>
    <p id="feedback-status" class="mt-2 hidden text-xs"></p>
  </form>
</div>

<script>
  const form = document.getElementById('feedback-form') as HTMLFormElement;
  const msg = document.getElementById('feedback-msg') as HTMLInputElement;
  const typeSelect = document.getElementById('feedback-type') as HTMLSelectElement;
  const btn = document.getElementById('feedback-btn') as HTMLButtonElement;
  const statusEl = document.getElementById('feedback-status')!;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!msg.value.trim()) return;

    btn.disabled = true;
    btn.textContent = 'Enviando...';

    try {
      const res = await fetch('/api/feedback', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ message: msg.value.trim(), type: typeSelect.value }),
      });

      if (res.ok) {
        statusEl.textContent = '¡Gracias! Tu mensaje fue enviado.';
        statusEl.className = 'mt-2 text-xs text-emerald-600';
        statusEl.classList.remove('hidden');
        msg.value = '';
      } else {
        statusEl.textContent = 'Error al enviar. Intenta de nuevo.';
        statusEl.className = 'mt-2 text-xs text-red-500';
        statusEl.classList.remove('hidden');
      }
    } catch {
      statusEl.textContent = 'Error de conexión.';
      statusEl.className = 'mt-2 text-xs text-red-500';
      statusEl.classList.remove('hidden');
    }

    btn.disabled = false;
    btn.textContent = 'Enviar';
  });
</script>
